<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<HediffDef>
		<defName>frontierwarden</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>frontier warden</label>
		<description>Raised by hard land and harder duty, this doctrine shapes a pawn into the colony's shield. They scout farther, shoot cleaner, mend faster, and stand firm where lines would otherwise break.</description>
		<defaultLabelColor>(107,142,35)</defaultLabelColor>
		<scenarioCanAdd>true</scenarioCanAdd>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="HediffCompProperties_GiveAbility">
				<abilityDefs>
					<li>FrontierBulwarkPulse</li>
				</abilityDefs>
			</li>
			<li Class="EasyMode.HediffCompProperties_GiveMultipleHediffs">
				<atSeverity>0</atSeverity>
				<disappearsAfterGiving>false</disappearsAfterGiving>
				<hediffsToGive>
					<li>
						<hediffDef>frontierwarden_pathfinder</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>frontierwarden_fireline</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>frontierwarden_fieldsurgeon</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>frontierwarden_breachfighter</hediffDef>
						<severity>1.0</severity>
					</li>
				</hediffsToGive>
			</li>
			<li Class="EasyMode.HediffCompProperties_ConditionalHediffDistributor">
				<checkIntervalTicks>90</checkIntervalTicks>
				<rules>
					<li>
						<key>warden-overwatch-matrix</key>
						<activeHediff>frontierwarden_overwatch_matrix</activeHediff>
						<activeSeverity>1.0</activeSeverity>
						<anyEquipmentTags>
							<li>Ranged</li>
						</anyEquipmentTags>
						<inCombat>Required</inCombat>
					</li>
					<li>
						<key>warden-breach-rampage</key>
						<activeHediff>frontierwarden_breach_rampage</activeHediff>
						<activeSeverity>1.0</activeSeverity>
						<anyEquipmentTags>
							<li>Melee</li>
						</anyEquipmentTags>
						<inCombat>Required</inCombat>
					</li>
					<li>
						<key>warden-camp-triage</key>
						<activeHediff>frontierwarden_camp_triage</activeHediff>
						<activeSeverity>1.0</activeSeverity>
						<drafted>Forbidden</drafted>
					</li>
				</rules>
			</li>
		</comps>
	</HediffDef>
	<HediffDef>
		<defName>frontierwarden_overwatch_matrix</defName>
		<hediffClass>HediffWithComps</hediffClass>
		<label>overwatch matrix</label>
		<description>Disciplined overwatch mode refines ranged cadence and exposes targets for line-breaking volleys.</description>
		<defaultLabelColor>(107,142,35)</defaultLabelColor>
		<isBad>false</isBad>
		<stages>
			<li>
				<statFactors>
					<ShootingAccuracyPawn>1.45</ShootingAccuracyPawn>
					<RangedCooldownFactor>0.56</RangedCooldownFactor>
					<AimingDelayFactor>0.56</AimingDelayFactor>
					<MoveSpeed>1.0</MoveSpeed>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>frontierwarden_breach_rampage</defName>
		<hediffClass>HediffWithComps</hediffClass>
		<label>breach rampage</label>
		<description>Melee breach posture trades caution for violent breakthrough and sustained close-quarters pressure.</description>
		<defaultLabelColor>(107,142,35)</defaultLabelColor>
		<isBad>false</isBad>
		<stages>
			<li>
				<statFactors>
					<MeleeDamageFactor>1.55</MeleeDamageFactor>
					<MeleeArmorPenetration>1.5</MeleeArmorPenetration>
					<MeleeCooldownFactor>0.58</MeleeCooldownFactor>
					<IncomingDamageFactor>1.15</IncomingDamageFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>frontierwarden_camp_triage</defName>
		<hediffClass>HediffWithComps</hediffClass>
		<label>camp triage command</label>
		<description>Between firefights, the warden shifts to logistics medicine and rapid stabilization of wounded allies.</description>
		<defaultLabelColor>(107,142,35)</defaultLabelColor>
		<isBad>false</isBad>
		<stages>
			<li>
				<statFactors>
					<MedicalTendQuality>1.65</MedicalTendQuality>
					<ImmunityGainSpeed>1.55</ImmunityGainSpeed>
					<InjuryHealingFactor>1.55</InjuryHealingFactor>
					<WorkSpeedGlobal>1.3</WorkSpeedGlobal>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>frontierwarden_pathfinder</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>pathfinder stride</label>
		<description>Hard-march conditioning improves movement, hauling, and field awareness.</description>
		<defaultLabelColor>(107,142,35)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>Moving</capacity>
						<offset>0.30</offset>
					</li>
					<li>
						<capacity>Sight</capacity>
						<offset>0.15</offset>
					</li>
				</capMods>
				<statOffsets>
					<CarryingCapacity>75</CarryingCapacity>
				</statOffsets>
				<statFactors>
					<MoveSpeed>1.35</MoveSpeed>
					<CarryingCapacity>1.6</CarryingCapacity>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>frontierwarden_fireline</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>fireline doctrine</label>
		<description>Battlefield drills improve aim discipline and target acquisition under pressure.</description>
		<defaultLabelColor>(107,142,35)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<statOffsets>
					<ShootingAccuracyPawn>8</ShootingAccuracyPawn>
				</statOffsets>
				<statFactors>
					<ShootingAccuracyPawn>1.6</ShootingAccuracyPawn>
					<RangedCooldownFactor>0.45</RangedCooldownFactor>
					<AimingDelayFactor>0.45</AimingDelayFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>frontierwarden_fieldsurgeon</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>field surgeon's calm</label>
		<description>Triaged instincts and steady hands sustain allies through prolonged campaigns.</description>
		<defaultLabelColor>(107,142,35)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>Manipulation</capacity>
						<offset>0.20</offset>
					</li>
					<li>
						<capacity>BloodFiltration</capacity>
						<offset>0.15</offset>
					</li>
				</capMods>
				<statFactors>
					<MedicalTendQuality>1.8</MedicalTendQuality>
					<ImmunityGainSpeed>1.5</ImmunityGainSpeed>
					<InjuryHealingFactor>1.5</InjuryHealingFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>frontierwarden_breachfighter</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>breachfighter resolve</label>
		<description>Close-quarters aggression and stubborn defense hold the line in chaos.</description>
		<defaultLabelColor>(107,142,35)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<statOffsets>
					<ArmorRating_Blunt>0.35</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.35</ArmorRating_Sharp>
					<ArmorRating_Heat>0.25</ArmorRating_Heat>
				</statOffsets>
				<statFactors>
					<MeleeDamageFactor>1.7</MeleeDamageFactor>
					<MeleeArmorPenetration>1.6</MeleeArmorPenetration>
					<MeleeCooldownFactor>0.55</MeleeCooldownFactor>
					<IncomingDamageFactor>0.7</IncomingDamageFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>frontier_bulwark_pulse</defName>
		<hediffClass>HediffWithComps</hediffClass>
		<label>bulwark pulse</label>
		<description>Warden pulse hardens posture and response speed for holding unstable defensive lines.</description>
		<defaultLabelColor>(107,142,35)</defaultLabelColor>
		<isBad>false</isBad>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>2100</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
			</li>
		</comps>
		<stages>
			<li>
				<statOffsets>
					<ArmorRating_Blunt>0.3</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.3</ArmorRating_Sharp>
				</statOffsets>
				<statFactors>
					<IncomingDamageFactor>0.62</IncomingDamageFactor>
					<MeleeCooldownFactor>0.65</MeleeCooldownFactor>
					<RangedCooldownFactor>0.68</RangedCooldownFactor>
					<AimingDelayFactor>0.68</AimingDelayFactor>
					<MoveSpeed>1.22</MoveSpeed>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<Def Class="EasyMode.ConditionalHediffProfileDef">
		<defName>EM_FrontierWardenSpine_CoreProfile</defName>
		<rules>
			<li>
				<key>core-pathfinder</key>
				<activeHediff>frontierwarden_pathfinder</activeHediff>
				<activeSeverity>1</activeSeverity>
			</li>
			<li>
				<key>core-fieldsurgeon</key>
				<activeHediff>frontierwarden_fieldsurgeon</activeHediff>
				<activeSeverity>1</activeSeverity>
			</li>
		</rules>
	</Def>

	<HediffDef ParentName="AddedBodyPartBase">
		<defName>EM_FrontierWardenSpine</defName>
		<label>frontier warden spine</label>
		<labelNoun>a frontier warden spine</labelNoun>
		<description>An installed service spine for colony defenders, combining patrol stride, field stabilization, and breach-response combat posture. It shifts between overwatch, melee line-breaking, and recovery command as conditions change.</description>
		<descriptionHyperlinks><ThingDef>EM_FrontierWardenSpine</ThingDef></descriptionHyperlinks>
		<spawnThingOnRemoved>EM_FrontierWardenSpine</spawnThingOnRemoved>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.3</partEfficiency>
			<betterThanNatural>true</betterThanNatural>
		</addedPartProps>
		<comps>
			<li Class="EasyMode.HediffCompProperties_ConditionalHediffDistributor">
				<checkIntervalTicks>90</checkIntervalTicks>
				<profiles>
					<li>EM_FrontierWardenSpine_CoreProfile</li>
				</profiles>
				<rules>
					<li>
						<key>warden-fireline</key>
						<activeHediff>frontierwarden_fireline</activeHediff>
						<activeSeverity>1</activeSeverity>
						<drafted>Required</drafted>
					</li>
					<li>
						<key>warden-overwatch-matrix</key>
						<activeHediff>frontierwarden_overwatch_matrix</activeHediff>
						<activeSeverity>1</activeSeverity>
						<anyEquipmentTags>
							<li>Ranged</li>
						</anyEquipmentTags>
						<inCombat>Required</inCombat>
					</li>
					<li>
						<key>warden-breachfighter</key>
						<activeHediff>frontierwarden_breachfighter</activeHediff>
						<activeSeverity>1</activeSeverity>
						<anyEquipmentTags>
							<li>Melee</li>
						</anyEquipmentTags>
						<inCombat>Required</inCombat>
					</li>
					<li>
						<key>warden-breach-rampage</key>
						<activeHediff>frontierwarden_breach_rampage</activeHediff>
						<activeSeverity>1</activeSeverity>
						<anyEquipmentTags>
							<li>Melee</li>
						</anyEquipmentTags>
						<inCombat>Required</inCombat>
						<healthPercent>0~0.7</healthPercent>
					</li>
					<li>
						<key>warden-camp-triage</key>
						<activeHediff>frontierwarden_camp_triage</activeHediff>
						<activeSeverity>1</activeSeverity>
						<drafted>Forbidden</drafted>
					</li>
				</rules>
			</li>
		</comps>
	</HediffDef>
</Defs>