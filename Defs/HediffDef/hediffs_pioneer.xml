<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<HediffDef>
		<defName>pioneerspirit</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>pioneer spirit</label>
		<description>The essence of exploration and discovery flows through their veins. Born to chart the unknown, they possess an otherworldly connection to the wilderness and an innate mastery over all forms of labor and combat.</description>
		<defaultLabelColor>(135,206,235)</defaultLabelColor>
		<scenarioCanAdd>true</scenarioCanAdd>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="HediffCompProperties_GiveAbility">
				<abilityDefs>
					<li>ColonyRally</li>
					<li>PioneerProclamation</li>
					<li>PioneerFrontierEdict</li>
				</abilityDefs>
			</li>
			<li Class="EasyMode.HediffCompProperties_GiveMultipleHediffs">
				<atSeverity>0</atSeverity>
				<disappearsAfterGiving>false</disappearsAfterGiving>
				<hediffsToGive>
					<li>
						<hediffDef>pioneerspirit_physical</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>pioneerspirit_industry</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>pioneerspirit_combat</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>pioneerspirit_resilience</hediffDef>
						<severity>1.0</severity>
					</li>
				</hediffsToGive>
			</li>
			<li Class="EasyMode.HediffCompProperties_ConditionalHediffDistributor">
				<checkIntervalTicks>90</checkIntervalTicks>
				<rules>
					<li>
						<key>pioneer-vanguard-fire</key>
						<activeHediff>pioneerspirit_vanguard_fire</activeHediff>
						<activeSeverity>1.0</activeSeverity>
						<anyEquipmentTags>
							<li>Ranged</li>
						</anyEquipmentTags>
						<inCombat>Required</inCombat>
					</li>
					<li>
						<key>pioneer-settler-engine</key>
						<activeHediff>pioneerspirit_settler_engine</activeHediff>
						<activeSeverity>1.0</activeSeverity>
						<drafted>Forbidden</drafted>
					</li>
					<li>
						<key>pioneer-laststand-overdrive</key>
						<activeHediff>pioneerspirit_laststand</activeHediff>
						<activeSeverity>1.0</activeSeverity>
						<healthPercent>0~0.4</healthPercent>
						<inCombat>Required</inCombat>
					</li>
				</rules>
			</li>
		</comps>
	</HediffDef>
	<HediffDef>
		<defName>pioneerspirit_physical</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>frontier vigor</label>
		<description>Refined physicality for exploration and hauling.</description>
		<defaultLabelColor>(135,206,235)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>0.25</offset>
					</li>
					<li>
						<capacity>Moving</capacity>
						<offset>0.50</offset>
					</li>
					<li>
						<capacity>Sight</capacity>
						<offset>0.40</offset>
					</li>
					<li>
						<capacity>Manipulation</capacity>
						<offset>0.45</offset>
					</li>
				</capMods>
				<statOffsets>
					<MoveSpeed>1.3</MoveSpeed>
					<CarryingCapacity>325</CarryingCapacity>
				</statOffsets>
				<statFactors>
					<MoveSpeed>1.5</MoveSpeed>
					<CarryingCapacity>2</CarryingCapacity>
					<WorkSpeedGlobal>2</WorkSpeedGlobal>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>pioneerspirit_industry</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>pioneer industry</label>
		<description>Mastery of labor and production.</description>
		<defaultLabelColor>(135,206,235)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<statOffsets>
					<MiningSpeed>2.0</MiningSpeed>
				</statOffsets>
				<statFactors>
					<WorkSpeedGlobal>1.2</WorkSpeedGlobal>
					<GlobalLearningFactor>3</GlobalLearningFactor>
					<MiningYield>2</MiningYield>
					<PlantHarvestYield>2</PlantHarvestYield>
					<DrugHarvestYield>2</DrugHarvestYield>
					<MedicalTendQuality>2</MedicalTendQuality>
					<ResearchSpeed>1.2</ResearchSpeed>
					<RangedCooldownFactor>0.15</RangedCooldownFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>pioneerspirit_combat</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>frontier marksmanship</label>
		<description>Tactical superiority and combat readiness.</description>
		<defaultLabelColor>(135,206,235)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<statOffsets>
					<ShootingAccuracyPawn>15</ShootingAccuracyPawn>
					<ArmorRating_Blunt>0.8</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.8</ArmorRating_Sharp>
					<ArmorRating_Heat>0.6</ArmorRating_Heat>
				</statOffsets>
				<statFactors>
					<RangedCooldownFactor>0.1</RangedCooldownFactor>
					<AimingDelayFactor>0.1</AimingDelayFactor>
					<ShootingAccuracyPawn>3</ShootingAccuracyPawn>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>pioneerspirit_resilience</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>survival instinct</label>
		<description>Endurance, recovery, and unshakable resolve.</description>
		<defaultLabelColor>(135,206,235)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<painFactor>0.3</painFactor>
				<capMods>
					<li>
						<capacity>BloodFiltration</capacity>
						<offset>0.35</offset>
					</li>
					<li>
						<capacity>BloodPumping</capacity>
						<offset>0.30</offset>
					</li>
					<li>
						<capacity>Metabolism</capacity>
						<offset>0.35</offset>
					</li>
					<li>
						<capacity>Breathing</capacity>
						<offset>0.25</offset>
					</li>
				</capMods>
				<regeneration>40</regeneration>
				<statOffsets>
					<MentalBreakThreshold>-0.4</MentalBreakThreshold>
				</statOffsets>
				<statFactors>
					<RestRateMultiplier>2</RestRateMultiplier>
					<ImmunityGainSpeed>2</ImmunityGainSpeed>
					<InjuryHealingFactor>2</InjuryHealingFactor>
					<GlobalLearningFactor>2</GlobalLearningFactor>
					<AimingDelayFactor>0.2</AimingDelayFactor>
					<IncomingDamageFactor>0.5</IncomingDamageFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>pioneerspirit_vanguard_fire</defName>
		<hediffClass>HediffWithComps</hediffClass>
		<label>vanguard fire discipline</label>
		<description>In active engagements, scouting doctrine folds into precision ranged pressure and rapid target cycling.</description>
		<defaultLabelColor>(135,206,235)</defaultLabelColor>
		<isBad>false</isBad>
		<stages>
			<li>
				<statFactors>
					<ShootingAccuracyPawn>1.5</ShootingAccuracyPawn>
					<RangedCooldownFactor>0.55</RangedCooldownFactor>
					<AimingDelayFactor>0.55</AimingDelayFactor>
					<MoveSpeed>1.18</MoveSpeed>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>pioneerspirit_settler_engine</defName>
		<hediffClass>HediffWithComps</hediffClass>
		<label>settler throughput engine</label>
		<description>Outside direct combat, the pioneer mindset reorganizes labor into a relentless high-output routine.</description>
		<defaultLabelColor>(135,206,235)</defaultLabelColor>
		<isBad>false</isBad>
		<stages>
			<li>
				<statFactors>
					<WorkSpeedGlobal>1.65</WorkSpeedGlobal>
					<ConstructionSpeed>1.7</ConstructionSpeed>
					<MiningSpeed>1.65</MiningSpeed>
					<PlantWorkSpeed>1.65</PlantWorkSpeed>
					<ResearchSpeed>1.5</ResearchSpeed>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>pioneerspirit_laststand</defName>
		<hediffClass>HediffWithComps</hediffClass>
		<label>frontier last stand</label>
		<description>When collapse is imminent, every reserve is burned to keep moving, shooting, and surviving through the worst minute.</description>
		<defaultLabelColor>(135,206,235)</defaultLabelColor>
		<isBad>false</isBad>
		<stages>
			<li>
				<painFactor>0.1</painFactor>
				<regeneration>75</regeneration>
				<statFactors>
					<IncomingDamageFactor>0.5</IncomingDamageFactor>
					<MoveSpeed>1.35</MoveSpeed>
					<RangedCooldownFactor>0.5</RangedCooldownFactor>
					<AimingDelayFactor>0.5</AimingDelayFactor>
					<MeleeCooldownFactor>0.62</MeleeCooldownFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>WorkGuidance</defName>
		<label>work guidance</label>
		<description>After receiving precise guidance on work details and steps, work proficiency improves noticeably and learning accelerates sharply for a short time.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<isBad>false</isBad>
		<stages>
			<li>
				<statFactors>
					<GlobalLearningFactor>3</GlobalLearningFactor>
				</statFactors>
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<showRemainingTime>true</showRemainingTime>
			</li>
			<li Class="HediffCompProperties_DisappearsOnDeath"/>
		</comps>
	</HediffDef>
	<HediffDef>
		<defName>pioneer_frontier_edict</defName>
		<label>frontier edict</label>
		<description>A short doctrine pulse synchronizes movement, labor cadence, and weapon handling for intense frontier response windows.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<isBad>false</isBad>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<showRemainingTime>true</showRemainingTime>
				<disappearsAfterTicks>2400</disappearsAfterTicks>
			</li>
			<li Class="HediffCompProperties_DisappearsOnDeath"/>
		</comps>
		<stages>
			<li>
				<statFactors>
					<MoveSpeed>2</MoveSpeed>
					<WorkSpeedGlobal>5</WorkSpeedGlobal>
					<RangedCooldownFactor>0.6</RangedCooldownFactor>
					<AimingDelayFactor>0.6</AimingDelayFactor>
					<MeleeCooldownFactor>0.6</MeleeCooldownFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>

	<Def Class="EasyMode.ConditionalHediffProfileDef">
		<defName>EM_PioneerSpine_CoreProfile</defName>
		<rules>
			<li>
				<key>core-industry</key>
				<activeHediff>pioneerspirit_industry</activeHediff>
				<activeSeverity>1</activeSeverity>
			</li>
			<li>
				<key>core-resilience</key>
				<activeHediff>pioneerspirit_resilience</activeHediff>
				<activeSeverity>1</activeSeverity>
			</li>
		</rules>
	</Def>

	<HediffDef ParentName="AddedBodyPartBase">
		<defName>EM_PioneerSpine</defName>
		<label>frontier lattice spine</label>
		<labelNoun>a frontier lattice spine</labelNoun>
		<description>An installed expeditionary command spine that alternates between colony-building throughput and high-speed response routines. It grants access to Neural Overclock and adapts around ranged pressure, work tempo, and last-stand survival states.</description>
		<descriptionHyperlinks>
			<ThingDef>EM_PioneerSpine</ThingDef>
			<AbilityDef>EasyMode_NeuralOverclock</AbilityDef>
		</descriptionHyperlinks>
		<spawnThingOnRemoved>EM_PioneerSpine</spawnThingOnRemoved>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.3</partEfficiency>
			<betterThanNatural>true</betterThanNatural>
		</addedPartProps>
		<comps>
			<li Class="HediffCompProperties_GiveAbility">
				<abilityDefs>
					<li>EasyMode_NeuralOverclock</li>
				</abilityDefs>
			</li>
			<li Class="EasyMode.HediffCompProperties_ConditionalHediffDistributor">
				<checkIntervalTicks>90</checkIntervalTicks>
				<profiles>
					<li>EM_PioneerSpine_CoreProfile</li>
				</profiles>
				<rules>
					<li>
						<key>pioneer-vanguard-fire</key>
						<activeHediff>pioneerspirit_vanguard_fire</activeHediff>
						<activeSeverity>1</activeSeverity>
						<anyEquipmentTags>
							<li>Ranged</li>
						</anyEquipmentTags>
					</li>
					<li>
						<key>pioneer-settler-engine</key>
						<activeHediff>pioneerspirit_settler_engine</activeHediff>
						<activeSeverity>1</activeSeverity>
						<drafted>Forbidden</drafted>
					</li>
					<li>
						<key>pioneer-laststand-overdrive</key>
						<activeHediff>pioneerspirit_laststand</activeHediff>
						<activeSeverity>1</activeSeverity>
						<healthPercent>0~0.4</healthPercent>
					</li>
				</rules>
			</li>
		</comps>
	</HediffDef>

	<HediffDef>
		<defName>WorkMotivation</defName>
		<hediffClass>HediffWithComps</hediffClass>
		<label>united as one</label>
		<description>Inspired by a rallying call, this pawn works with exceptional drive and focus. All tasks are performed faster, movement quickens, and every need is restored on a steady pulse while the motivation holds.</description>
		<defaultLabelColor>(255,215,0)</defaultLabelColor>
		<isBad>false</isBad>
		<maxSeverity>1.0</maxSeverity>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>60000</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
			</li>
			<li Class="EasyMode.HediffCompProperties_ColonyRallyMaintenance">
				<tickInterval>240</tickInterval>
				<followupHediffDef>ColonyRallyFatigue</followupHediffDef>
			</li>
		</comps>
		<stages>
			<li>
				<statOffsets>
					<WorkSpeedGlobal>0.75</WorkSpeedGlobal>
					<MoveSpeed>0.5</MoveSpeed>
				</statOffsets>
			</li>
		</stages>
	</HediffDef>

	<HediffDef>
		<defName>ColonyRallyFatigue</defName>
		<hediffClass>HediffWithComps</hediffClass>
		<label>rally fatigue</label>
		<description>The surge has passed and the colony feels the letdown. Food and rest slip away twice as fast for a while.</description>
		<defaultLabelColor>(205,92,92)</defaultLabelColor>
		<isBad>true</isBad>
		<maxSeverity>1.0</maxSeverity>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>30000</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
			</li>
		</comps>
		<stages>
			<li />
		</stages>
	</HediffDef>
		<HediffDef>
		<defName>EasyMode_NeuralOverclock</defName>
		<label>neural overclock</label>
		<description>The nervous system and musculature are operating far beyond normal safety limits. Motion becomes explosively fast and precise while accumulating tissue strain across the body.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<isBad>false</isBad>
		<maxSeverity>1</maxSeverity>
		<comps>
			<li Class="EasyMode.HediffCompProperties_NeuralOverclock">
				<damageIntervalTicks>60</damageIntervalTicks>
				<damageRange>1~2</damageRange>
				<internalPartChance>0.01</internalPartChance>
				<trailSampleIntervalTicks>4</trailSampleIntervalTicks>
				<trailLifetimeTicks>20</trailLifetimeTicks>
				<maxTrailSnapshots>5</maxTrailSnapshots>
			</li>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>300</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
			</li>
			<li Class="HediffCompProperties_DisappearsOnDeath" />
		</comps>
		<stages>
			<li>
				<statOffsets>
					<MoveSpeed>50</MoveSpeed>
				</statOffsets>
				<statFactors>
					<MeleeHitChance>1.5</MeleeHitChance>
					<AimingDelayFactor>0.35</AimingDelayFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>

	<HediffDef ParentName="InjuryBase">
		<defName>EasyMode_NeuralOverclockStrain</defName>
		<label>overclock strain</label>
		<labelNoun>an overclock strain</labelNoun>
		<description>Localized neural and muscular damage caused by forcing the body beyond its safe operating limits.</description>
		<displayWound>false</displayWound>
		<comps>
			<li Class="HediffCompProperties_TendDuration">
				<labelTendedWell>stabilized</labelTendedWell>
				<labelTendedWellInner>stabilized</labelTendedWellInner>
				<labelSolidTendedWell>stabilized</labelSolidTendedWell>
			</li>
		</comps>
		<injuryProps>
			<painPerSeverity>0.006</painPerSeverity>
			<bleedRate>0</bleedRate>
			<canMerge>true</canMerge>
			<destroyedLabel>Overstrained</destroyedLabel>
			<destroyedOutLabel>Overstrained</destroyedOutLabel>
		</injuryProps>
	</HediffDef>
</Defs>
