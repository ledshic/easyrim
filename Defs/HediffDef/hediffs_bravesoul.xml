<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<HediffDef>
		<defName>bravesoul</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>brave soul</label>
		<description>An immortal warrior's spirit burns within, forged through countless battles. Death itself bends to their indomitable will, and their combat prowess transcends mortal limitations.</description>
		<defaultLabelColor>(0,206,209)</defaultLabelColor>
		<scenarioCanAdd>true</scenarioCanAdd>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="EasyMode.HediffCompProperties_GiveMultipleHediffs">
				<atSeverity>0</atSeverity>
				<disappearsAfterGiving>false</disappearsAfterGiving>
				<hediffsToGive>
					<li>
						<hediffDef>bravesoul_cognitive</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>bravesoul_physical</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>bravesoul_vitals</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>bravesoul_combat</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>bravesoul_spirit</hediffDef>
						<severity>1.0</severity>
					</li>
				</hediffsToGive>
			</li>
		</comps>
	</HediffDef>
	<HediffDef>
		<defName>bravesoul_cognitive</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>cognitive fervor</label>
		<description>Sharpened mind and heightened perception fueled by warrior spirit.</description>
		<defaultLabelColor>(0,206,209)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>0.30</offset>
					</li>
					<li>
						<capacity>Sight</capacity>
						<offset>0.35</offset>
					</li>
				</capMods>
				<statFactors>
					<GlobalLearningFactor>5</GlobalLearningFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>bravesoul_physical</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>physical might</label>
		<description>Unmatched agility and control honed through countless battles.</description>
		<defaultLabelColor>(0,206,209)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>Moving</capacity>
						<offset>0.40</offset>
					</li>
					<li>
						<capacity>Manipulation</capacity>
						<offset>0.50</offset>
					</li>
				</capMods>
				<statOffsets>
					<MoveSpeed>0.8</MoveSpeed>
					<CarryingCapacity>50</CarryingCapacity>
				</statOffsets>
				<statFactors>
					<CarryingCapacity>2</CarryingCapacity>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
