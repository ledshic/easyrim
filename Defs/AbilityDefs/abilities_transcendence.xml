<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<AbilityDef ParentName="AbilityTouchBase">
		<defName>ResurrectNoCost</defName>
		<label>eternal revival</label>
		<description>Harness advanced archite technology flowing through the bloodstream to restore life to the deceased. These microscopic machines repair cellular damage, restart vital functions, and reconstruct neural pathways. The success and quality of resurrection depends on the corpse's condition - fresher bodies retain more memories and physical integrity, while older remains may suffer permanent cognitive or physical impairments.</description>
		<iconPath>UI/Abilities/Resurrect</iconPath>
		<cooldownTicksRange>60000~120000</cooldownTicksRange>
		<warmupMote>Mote_ResurrectAbility</warmupMote>
		<warmupStartSound>Resurrect_Cast</warmupStartSound>
		<displayOrder>600</displayOrder>
		<hostile>false</hostile>
		<sendMessageOnCooldownComplete>true</sendMessageOnCooldownComplete>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<charges>3</charges>
		<cooldownPerCharge>true</cooldownPerCharge>
		<verbProperties>
			<verbClass>Verb_CastAbilityTouch</verbClass>
			<drawAimPie>false</drawAimPie>
			<range>-1</range>
			<warmupTime>2</warmupTime>
			<soundCast>Resurrect_Resolve</soundCast>
			<targetParams>
				<canTargetPawns>false</canTargetPawns>
				<canTargetBuildings>false</canTargetBuildings>
				<canTargetCorpses>true</canTargetCorpses>
				<canTargetMechs>false</canTargetMechs>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="CompProperties_Resurrect" />
		</comps>
	</AbilityDef>
	<AbilityDef>
		<defName>NanoDisassemblyTransit</defName>
		<label>nano disassembly transit</label>
		<description>Activate the integrated nano-transit matrix to disassemble your body into a compressed data stream at the subatomic level. Trillions of nanomachines encode every molecule and neural pattern, broadcast the data packet via synchronized orbital relay, then reconstruct the physical form with atomic precision at the designated coordinates. Unlike primitive transport pods, no physical container is required - the body itself becomes the signal.</description>
		<iconPath>UI/Abilities/Skip</iconPath>
		<cooldownTicksRange>5000</cooldownTicksRange>
		<!-- 2 in-game hours -->
		<showPsycastEffects>false</showPsycastEffects>
		<sendMessageOnCooldownComplete>true</sendMessageOnCooldownComplete>
		<displayGizmoWhileUndrafted>true</displayGizmoWhileUndrafted>
		<disableGizmoWhileUndrafted>false</disableGizmoWhileUndrafted>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<range>9999</range>
			<warmupTime>1.5</warmupTime>
			<soundCast>Psycast_Skip_Entry</soundCast>
			<useableInPocketMaps>true</useableInPocketMaps>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
				<canTargetPawns>false</canTargetPawns>
			</targetParams>
		</verbProperties>
		<comps>
			<!-- Entry flash at caster's position when teleport begins -->
			<li Class="CompProperties_AbilityEffecterOnCaster">
				<effecterDef>Skip_EntryNoDelay</effecterDef>
				<maintainForTicks>60</maintainForTicks>
			</li>
			<!-- Actual teleport logic -->
			<li Class="EasyMode.CompProperties_NanoTeleport" />
			<!-- Exit flash at destination -->
			<li Class="CompProperties_AbilityEffecterOnTarget">
				<effecterDef>Skip_Exit</effecterDef>
				<maintainForTicks>60</maintainForTicks>
			</li>
			<li Class="CompProperties_AbilityFleckOnTarget">
				<fleckDefs>
					<li>PsycastSkipInnerExit</li>
					<li>PsycastSkipOuterRingExit</li>
				</fleckDefs>
				<sound>Psycast_Skip_Exit</sound>
				<preCastTicks>5</preCastTicks>
			</li>
		</comps>
	</AbilityDef>
	<AbilityDef>
		<defName>TranscendentDropPods</defName>
		<label>overmind drops</label>
		<description>Simulates a mechanoid overmind control signal, ordering nearby logistics satellites to dispatch several single-use drop pods to the target area.</description>
		<iconPath>UI/Commands/CallDropPods</iconPath>
		<cooldownTicksRange>30000~45000</cooldownTicksRange>
		<displayOrder>300</displayOrder>
		<sendMessageOnCooldownComplete>true</sendMessageOnCooldownComplete>
		<displayGizmoWhileUndrafted>true</displayGizmoWhileUndrafted>
		<disableGizmoWhileUndrafted>false</disableGizmoWhileUndrafted>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<charges>2</charges>
		<cooldownPerCharge>true</cooldownPerCharge>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<range>500</range>
			<warmupTime>0.5</warmupTime>
			<soundCast>Ability_CallMechanoids</soundCast>
			<useableInPocketMaps>false</useableInPocketMaps>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="CompProperties_DropMechPods">
				<numPods>3~4</numPods>
			</li>
		</comps>
	</AbilityDef>
</Defs>
