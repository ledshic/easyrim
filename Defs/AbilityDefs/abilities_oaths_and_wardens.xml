<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<AbilityDef>
		<defName>ArchotechProtocolSurge</defName>
		<label>protocol surge</label>
		<description>Force the oath's core routines into a short overclock. Work, research, and combat throughput spike briefly, then normalize.</description>
		<iconPath>UI/Abilities/WorkDrive</iconPath>
		<showPsycastEffects>false</showPsycastEffects>
		<hostile>false</hostile>
		<targetRequired>false</targetRequired>
		<displayGizmoWhileUndrafted>true</displayGizmoWhileUndrafted>
		<disableGizmoWhileUndrafted>false</disableGizmoWhileUndrafted>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<cooldownTicksRange>20000</cooldownTicksRange>
		<sendMessageOnCooldownComplete>true</sendMessageOnCooldownComplete>
		<statBases>
			<Ability_Duration>2400</Ability_Duration>
		</statBases>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<drawAimPie>false</drawAimPie>
			<warmupTime>1.5</warmupTime>
			<targetable>false</targetable>
			<targetParams>
				<canTargetSelf>true</canTargetSelf>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>CompAbilityEffect_GiveHediff</compClass>
				<hediffDef>archotech_protocol_surge</hediffDef>
				<onlyApplyToSelf>true</onlyApplyToSelf>
				<applicableToMechs>false</applicableToMechs>
				<canTargetBaby>false</canTargetBaby>
			</li>
		</comps>
	</AbilityDef>
	<AbilityDef>
		<defName>ArchotechLockstep</defName>
		<label>lockstep mark</label>
		<description>Mark a hostile target with predictive lock telemetry, reducing its mobility and evasive timing while increasing damage received.</description>
		<iconPath>UI/Abilities/LeaderSpeech</iconPath>
		<showPsycastEffects>false</showPsycastEffects>
		<hostile>true</hostile>
		<displayGizmoWhileUndrafted>true</displayGizmoWhileUndrafted>
		<disableGizmoWhileUndrafted>false</disableGizmoWhileUndrafted>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<cooldownTicksRange>21000</cooldownTicksRange>
		<sendMessageOnCooldownComplete>true</sendMessageOnCooldownComplete>
		<statBases>
			<Ability_Duration>3000</Ability_Duration>
		</statBases>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<drawAimPie>false</drawAimPie>
			<range>24.9</range>
			<warmupTime>1.4</warmupTime>
			<targetParams>
				<canTargetPawns>true</canTargetPawns>
				<canTargetAnimals>true</canTargetAnimals>
				<canTargetSelf>false</canTargetSelf>
				<canTargetBuildings>false</canTargetBuildings>
				<canTargetMechs>false</canTargetMechs>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>CompAbilityEffect_GiveHediff</compClass>
				<hediffDef>archotech_lockstep_marked</hediffDef>
				<onlyBrain>false</onlyBrain>
				<applicableToMechs>false</applicableToMechs>
				<canTargetBaby>false</canTargetBaby>
			</li>
		</comps>
	</AbilityDef>
	<AbilityDef>
		<defName>FrontierBulwarkPulse</defName>
