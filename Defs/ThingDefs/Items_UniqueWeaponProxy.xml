<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Symbolic product for recipe UI. Runtime recipe patch replaces it with an actual matching unique weapon. -->
  <ThingDef ParentName="ResourceBase">
    <defName>EasyMode_RandomUniqueRangedWeaponProxy</defName>
    <label>hand-finished custom weapon</label>
    <description>A new personal weapon that has been purpose-built, reinforced, and customized.</description>
    <graphicData>
      <texPath>Things/Item/Special/TechprofSubpersonaCore</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <thingCategories>
      <li>ResourcesRaw</li>
    </thingCategories>
    <statBases>
      <Mass>0.1</Mass>
      <MarketValue>1</MarketValue>
      <MaxHitPoints>50</MaxHitPoints>
      <Flammability>0</Flammability>
    </statBases>
    <stackLimit>1</stackLimit>
    <selectable>false</selectable>
    <alwaysHaulable>false</alwaysHaulable>
    <neverMultiSelect>true</neverMultiSelect>
    <tradeability>None</tradeability>
    <tickerType>Never</tickerType>
  </ThingDef>
</Defs>
