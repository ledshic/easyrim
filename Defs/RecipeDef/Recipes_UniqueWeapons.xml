<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <RecipeDef>
    <defName>EasyMode_ConvertToUniqueRangedWeapon</defName>
    <label>weapon customization</label>
    <description>Redesign, reinforce, and customize a ranged weapon. With the gunsmith's own inspiration, turn an ordinary weapon into a one-of-a-kind signature piece. You can also strip and rebuild an existing customized weapon into a brand-new personal collection piece.</description>
    <jobString>Customizing weapon.</jobString>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Machining</soundWorking>
    <unfinishedThingDef>UnfinishedGun</unfinishedThingDef>
    <workAmount>30000</workAmount>
    <ingredients>
      <li>
        <filter>
          <thingCategories>
            <li>Weapons</li>
          </thingCategories>
        </filter>
        <count>1</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Plasteel</li>
          </thingDefs>
        </filter>
        <count>80</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>12</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentSpacer</li>
          </thingDefs>
        </filter>
        <count>4</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>180</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>WoodLog</li>
          </thingDefs>
        </filter>
        <count>120</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Chemfuel</li>
          </thingDefs>
        </filter>
        <count>40</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingCategories>
        <li>Weapons</li>
      </thingCategories>
      <thingDefs>
        <li>Plasteel</li>
        <li>ComponentIndustrial</li>
        <li>ComponentSpacer</li>
        <li>Steel</li>
        <li>WoodLog</li>
        <li>Chemfuel</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <EasyMode_RandomUniqueRangedWeaponProxy>1</EasyMode_RandomUniqueRangedWeaponProxy>
    </products>
    <skillRequirements>
      <Crafting>10</Crafting>
    </skillRequirements>
    <displayPriority>240</displayPriority>
    <recipeUsers>
      <li>FabricationBench</li>
    </recipeUsers>
  </RecipeDef>
</Defs>
