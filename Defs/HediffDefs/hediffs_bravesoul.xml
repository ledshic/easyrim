<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- Parent hediff that grants all Brave Soul sub-hediffs -->
	<HediffDef>
		<defName>bravesoul</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>brave soul</label>
		<description>An immortal warrior's spirit burns within, forged through countless battles. Death itself bends to their indomitable will, and their combat prowess transcends mortal limitations.</description>
		<defaultLabelColor>(0,206,209)</defaultLabelColor>
		<scenarioCanAdd>true</scenarioCanAdd>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="EasyMode.HediffCompProperties_GiveMultipleHediffs">
				<atSeverity>0</atSeverity>
				<disappearsAfterGiving>false</disappearsAfterGiving>
				<hediffsToGive>
					<li>
						<hediffDef>bravesoul_cognitive</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>bravesoul_physical</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>bravesoul_vitals</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>bravesoul_combat</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>bravesoul_spirit</hediffDef>
						<severity>1.0</severity>
					</li>
				</hediffsToGive>
			</li>
		</comps>
	</HediffDef>
	<!-- Mind and perception enhancements -->
	<HediffDef>
		<defName>bravesoul_cognitive</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>cognitive fervor</label>
		<description>Sharpened mind and heightened perception fueled by warrior spirit.</description>
		<defaultLabelColor>(0,206,209)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>0.30</offset>
					</li>
					<li>
						<capacity>Sight</capacity>
						<offset>0.35</offset>
					</li>
				</capMods>
				<statFactors>
					<GlobalLearningFactor>5</GlobalLearningFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<!-- Movement and manipulation power -->
	<HediffDef>
		<defName>bravesoul_physical</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>physical might</label>
		<description>Unmatched agility and control honed through countless battles.</description>
		<defaultLabelColor>(0,206,209)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>Moving</capacity>
						<offset>0.40</offset>
					</li>
					<li>
						<capacity>Manipulation</capacity>
						<offset>0.50</offset>
					</li>
				</capMods>
				<statOffsets>
					<MoveSpeed>0.8</MoveSpeed>
					<CarryingCapacity>50</CarryingCapacity>
				</statOffsets>
				<statFactors>
					<CarryingCapacity>2</CarryingCapacity>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<!-- Vital systems resilience and regeneration -->
	<HediffDef>
		<defName>bravesoul_vitals</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>vital ascendance</label>
		<description>Reinforced organs and accelerated recovery.</description>
		<defaultLabelColor>(0,206,209)</defaultLabelColor>
		<maxSeverity>5.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<!-- 狂战士之血：生命值越低，阶段越高，从而提升回复能力 -->
			<li Class="EasyMode.HediffCompProperties_BerserkerBlood"></li>
		</comps>
		<stages>
			<li>
				<minSeverity>1</minSeverity>
				<capMods>
					<li>
						<capacity>BloodFiltration</capacity>
						<offset>0.50</offset>
					</li>
					<li>
						<capacity>BloodPumping</capacity>
						<offset>0.60</offset>
					</li>
					<li>
						<capacity>Metabolism</capacity>
						<offset>0.40</offset>
					</li>
					<li>
						<capacity>Breathing</capacity>
						<offset>0.30</offset>
					</li>
				</capMods>
				<regeneration>150</regeneration>
				<statFactors>
					<RestRateMultiplier>1.25</RestRateMultiplier>
					<ImmunityGainSpeed>1.25</ImmunityGainSpeed>
					<InjuryHealingFactor>1.25</InjuryHealingFactor>
				</statFactors>
			</li>
			<li>
				<minSeverity>2</minSeverity>
				<capMods>
					<li>
						<capacity>BloodFiltration</capacity>
						<offset>0.50</offset>
					</li>
					<li>
						<capacity>BloodPumping</capacity>
						<offset>0.60</offset>
					</li>
					<li>
						<capacity>Metabolism</capacity>
						<offset>0.40</offset>
					</li>
					<li>
						<capacity>Breathing</capacity>
						<offset>0.30</offset>
					</li>
				</capMods>
				<regeneration>200</regeneration>
				<statFactors>
					<RestRateMultiplier>1.5</RestRateMultiplier>
					<ImmunityGainSpeed>1.5</ImmunityGainSpeed>
					<InjuryHealingFactor>1.5</InjuryHealingFactor>
				</statFactors>
			</li>
			<li>
				<minSeverity>3</minSeverity>
				<capMods>
					<li>
						<capacity>BloodFiltration</capacity>
						<offset>0.50</offset>
					</li>
					<li>
						<capacity>BloodPumping</capacity>
						<offset>0.60</offset>
					</li>
					<li>
						<capacity>Metabolism</capacity>
						<offset>0.40</offset>
					</li>
					<li>
						<capacity>Breathing</capacity>
						<offset>0.30</offset>
					</li>
				</capMods>
				<regeneration>250</regeneration>
				<statFactors>
					<RestRateMultiplier>2.0</RestRateMultiplier>
					<ImmunityGainSpeed>2.0</ImmunityGainSpeed>
					<InjuryHealingFactor>2.0</InjuryHealingFactor>
				</statFactors>
			</li>
			<li>
				<minSeverity>4</minSeverity>
				<capMods>
					<li>
						<capacity>BloodFiltration</capacity>
						<offset>0.50</offset>
					</li>
					<li>
						<capacity>BloodPumping</capacity>
						<offset>0.60</offset>
					</li>
					<li>
						<capacity>Metabolism</capacity>
						<offset>0.40</offset>
					</li>
					<li>
						<capacity>Breathing</capacity>
						<offset>0.30</offset>
					</li>
				</capMods>
				<regeneration>325</regeneration>
				<statFactors>
					<RestRateMultiplier>2.5</RestRateMultiplier>
					<ImmunityGainSpeed>2.5</ImmunityGainSpeed>
					<InjuryHealingFactor>2.5</InjuryHealingFactor>
				</statFactors>
			</li>
			<li>
				<minSeverity>5</minSeverity>
				<capMods>
					<li>
						<capacity>BloodFiltration</capacity>
						<offset>0.50</offset>
					</li>
					<li>
						<capacity>BloodPumping</capacity>
						<offset>0.60</offset>
					</li>
					<li>
						<capacity>Metabolism</capacity>
						<offset>0.40</offset>
					</li>
					<li>
						<capacity>Breathing</capacity>
						<offset>0.30</offset>
					</li>
				</capMods>
				<regeneration>400</regeneration>
				<statFactors>
					<RestRateMultiplier>3.0</RestRateMultiplier>
					<ImmunityGainSpeed>3.0</ImmunityGainSpeed>
					<InjuryHealingFactor>3.0</InjuryHealingFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<!-- Combat mastery and damage mitigation -->
	<HediffDef>
		<defName>bravesoul_combat</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>combat mastery</label>
		<description>Supreme martial prowess and adaptive defenses.</description>
		<defaultLabelColor>(0,206,209)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<statOffsets>
					<ArmorRating_Blunt>1</ArmorRating_Blunt>
					<ArmorRating_Sharp>1</ArmorRating_Sharp>
					<ArmorRating_Heat>0.6</ArmorRating_Heat>
				</statOffsets>
				<statFactors>
					<MeleeHitChance>5</MeleeHitChance>
					<MeleeArmorPenetration>2</MeleeArmorPenetration>
					<MeleeCooldownFactor>0.15</MeleeCooldownFactor>
					<MeleeDamageFactor>1.75</MeleeDamageFactor>
					<MeleeDodgeChance>2</MeleeDodgeChance>
					<StaggerDurationFactor>0.5</StaggerDurationFactor>
					<IncomingDamageFactor>0.3</IncomingDamageFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<!-- Indomitable spirit and mental fortitude -->
	<HediffDef>
		<defName>bravesoul_spirit</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>indomitable spirit</label>
		<description>Unbreakable resolve that steadies the mind in the face of death.</description>
		<defaultLabelColor>(0,206,209)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<statOffsets>
					<MentalBreakThreshold>-0.3</MentalBreakThreshold>
				</statOffsets>
			</li>
		</stages>
	</HediffDef>
</Defs>
