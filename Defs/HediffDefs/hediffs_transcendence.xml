<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<HediffDef>
		<defName>transcendence</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>transcendence</label>
		<description>Advanced glitter tech mechanites have fundamentally transformed the body, elevating it beyond mortal limitations. Every biological system operates at peak efficiency while the mind achieves perfect clarity.</description>
		<defaultLabelColor>(192,192,192)</defaultLabelColor>
		<priceOffset>-3000</priceOffset>
		<scenarioCanAdd>true</scenarioCanAdd>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="EasyMode.HediffCompProperties_GiveMultipleHediffs">
				<atSeverity>0</atSeverity>
				<disappearsAfterGiving>false</disappearsAfterGiving>
				<hediffsToGive>
					<li>
						<hediffDef>transcendence_cognitive</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>transcendence_physical</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>transcendence_biological</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>transcendence_environmental</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>transcendence_psychic</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>adaptive_armor</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>transcendence_battle_morph_verbs</hediffDef>
						<severity>1.0</severity>
					</li>
				</hediffsToGive>
			</li>
			<li Class="EasyMode.HediffCompProperties_ConditionalHediffDistributor">
				<checkIntervalTicks>120</checkIntervalTicks>
				<rules>
					<li>
						<key>transcendence-ranged-calibration</key>
						<activeHediff>EM_NexusSpine_RangedAdaptation</activeHediff>
						<activeSeverity>1</activeSeverity>
						<anyEquipmentTags>
							<li>Ranged</li>
						</anyEquipmentTags>
					</li>
					<li MayRequire="Ludeon.RimWorld.Biotech">
						<key>transcendence-gene-strong-melee</key>
						<activeHediff>EM_NexusSpine_GeneAdaptation</activeHediff>
						<activeSeverity>1</activeSeverity>
						<allGenes>
							<li>MeleeDamage_Strong</li>
						</allGenes>
					</li>
				</rules>
			</li>
		</comps>
	</HediffDef>
	<HediffDef>
		<defName>transcendence_cognitive</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>cognitive enhancement</label>
		<description>Enhanced mental capabilities from mechanite integration.</description>
		<defaultLabelColor>(192,192,192)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>1.20</offset>
					</li>
					<li>
						<capacity>Sight</capacity>
						<offset>0.25</offset>
					</li>
				</capMods>
				<statFactors>
					<MeleeCooldownFactor>0.6</MeleeCooldownFactor>
					<MeleeHitChance>1.4</MeleeHitChance>
					<MeleeArmorPenetration>1.6</MeleeArmorPenetration>
					<MeleeDamageFactor>1.5</MeleeDamageFactor>
					<MeleeDodgeChance>1.6</MeleeDodgeChance>
					<RangedCooldownFactor>0.4</RangedCooldownFactor>
					<ShootingAccuracyPawn>1.8</ShootingAccuracyPawn>
					<AimingDelayFactor>0.4</AimingDelayFactor>
					<StudyEfficiency>2</StudyEfficiency>
					<WorkSpeedGlobalOffsetMech>2</WorkSpeedGlobalOffsetMech>
					<GlobalLearningFactor>2</GlobalLearningFactor>
					<WorkSpeedGlobal>2</WorkSpeedGlobal>
					<NegotiationAbility>2</NegotiationAbility>
					<ResearchSpeed>2</ResearchSpeed>
					<ConversionPower>2</ConversionPower>
					<SocialImpact>2</SocialImpact>
					<TradePriceImprovement>2</TradePriceImprovement>
					<GeneralLaborSpeed>2</GeneralLaborSpeed>
				</statFactors>
				<painFactor>0</painFactor>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>transcendence_physical</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>physical enhancement</label>
		<description>Enhanced physical capabilities from mechanite integration.</description>
		<defaultLabelColor>(192,192,192)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>Moving</capacity>
						<offset>0.15</offset>
					</li>
					<li>
						<capacity>Manipulation</capacity>
						<offset>0.20</offset>
					</li>
				</capMods>
				<statOffsets>
					<PawnBeauty>3</PawnBeauty>
					<MechBandwidth>12</MechBandwidth>
					<MoveSpeed>0.2</MoveSpeed>
					<CarryingCapacity>25</CarryingCapacity>
					<ArmorRating_Blunt>0.2</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.2</ArmorRating_Sharp>
					<ArmorRating_Heat>2</ArmorRating_Heat>
				</statOffsets>
				<statFactors>
					<MoveSpeed>1.25</MoveSpeed>
					<IncomingDamageFactor>0.2</IncomingDamageFactor>
					<StaggerDurationFactor>0</StaggerDurationFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>transcendence_biological</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>biological enhancement</label>
		<description>Enhanced biological systems from mechanite integration.</description>
		<defaultLabelColor>(192,192,192)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="HediffCompProperties_GiveAbility">
				<abilityDefs>
					<li>ResurrectNoCost</li>
					<li>ArchotechRestoration</li>
					<li>TranscendentDropPods</li>
					<li>NanoDisassemblyTransit</li>
				</abilityDefs>
			</li>
			<li Class="HediffCompProperties_HealPermanentWounds" />
			<li Class="EasyMode.HediffCompProperties_NanoWatch">
				<tickInterval>60</tickInterval>
				<minRespawnDays>3</minRespawnDays>
				<maxRespawnDays>5</maxRespawnDays>
			</li>
		</comps>
		<preventsDeath>true</preventsDeath>
		<keepOnBodyPartRestoration>True</keepOnBodyPartRestoration>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>BloodFiltration</capacity>
						<offset>0.90</offset>
					</li>
					<li>
						<capacity>BloodPumping</capacity>
						<offset>0.25</offset>
					</li>
					<li>
						<capacity>Metabolism</capacity>
						<offset>0.30</offset>
					</li>
					<li>
						<capacity>Breathing</capacity>
						<offset>0.20</offset>
					</li>
				</capMods>
				<regeneration>70</regeneration>
				<disablesNeeds>
					<li>Rest</li>
					<li>Comfort</li>
					<li>Joy</li>
					<li>Food</li>
					<li>Mood</li>
					<li>Beauty</li>
					<li>Outdoors</li>
					<li>Indoors</li>
				</disablesNeeds>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>transcendence_environmental</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>environmental adaptation</label>
		<description>Enhanced resistance to environmental hazards from mechanite integration.</description>
		<defaultLabelColor>(192,192,192)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<statOffsets>
					<VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">1.2</VacuumResistance>
					<ComfyTemperatureMin>-250</ComfyTemperatureMin>
					<ComfyTemperatureMax>250</ComfyTemperatureMax>
					<Flammability>-1.2</Flammability>
					<ToxicResistance>1</ToxicResistance>
				</statOffsets>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>transcendence_psychic</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>psychic enhancement</label>
		<description>Enhanced psychic capabilities from mechanite integration.</description>
		<defaultLabelColor>(192,192,192)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="EasyMode.HediffCompProperties_RestorePsy" />
		</comps>
		<stages>
			<li>
				<statFactors>
					<PsychicSensitivity>10</PsychicSensitivity>
					<MeditationFocusGain>10</MeditationFocusGain>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>psylink_fullpower</defName>
		<hediffClass>Hediff_Psylink</hediffClass>
		<label>psylink level 6</label>
		<description>A psylink with the highest level of psychic capability.</description>
		<scenarioCanAdd>true</scenarioCanAdd>
		<isBad>false</isBad>
		<defaultLabelColor>(128,0,255)</defaultLabelColor>
		<priceImpact>false</priceImpact>
		<initialSeverity>6</initialSeverity>
		<minSeverity>0</minSeverity>
		<maxSeverity>6</maxSeverity>
		<keepOnBodyPartRestoration>True</keepOnBodyPartRestoration>
		<stages>
			<li>
				<minSeverity>1</minSeverity>
				<statFactors>
					<PsychicEntropyMax>1.0</PsychicEntropyMax>
					<PsychicEntropyRecoveryRate>1</PsychicEntropyRecoveryRate>
				</statFactors>
			</li>
			<li>
				<minSeverity>2</minSeverity>
				<statFactors>
					<PsychicEntropyMax>1.3334</PsychicEntropyMax>
					<PsychicEntropyRecoveryRate>1.125</PsychicEntropyRecoveryRate>
				</statFactors>
			</li>
			<li>
				<minSeverity>3</minSeverity>
				<statFactors>
					<PsychicEntropyMax>1.6667</PsychicEntropyMax>
					<PsychicEntropyRecoveryRate>1.25</PsychicEntropyRecoveryRate>
				</statFactors>
			</li>
			<li>
				<minSeverity>4</minSeverity>
				<statFactors>
					<PsychicEntropyMax>2.0</PsychicEntropyMax>
					<PsychicEntropyRecoveryRate>1.375</PsychicEntropyRecoveryRate>
				</statFactors>
			</li>
			<li>
				<minSeverity>5</minSeverity>
				<statFactors>
					<PsychicEntropyMax>2.3334</PsychicEntropyMax>
					<PsychicEntropyRecoveryRate>1.5</PsychicEntropyRecoveryRate>
				</statFactors>
			</li>
			<li>
				<minSeverity>6</minSeverity>
				<statFactors>
					<PsychicEntropyMax>2.6667</PsychicEntropyMax>
					<PsychicEntropyRecoveryRate>1.625</PsychicEntropyRecoveryRate>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>adaptive_armor</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>adaptive armor</label>
		<description>Advanced adaptive armor that responds to the wearer's health condition. As health decreases, the armor becomes more protective but restricts movement.</description>
		<defaultLabelColor>(100,100,100)</defaultLabelColor>
		<scenarioCanAdd>true</scenarioCanAdd>
		<maxSeverity>5.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="EasyMode.HediffCompProperties_AdaptiveArmor"></li>
		</comps>
		<stages>
			<li>
				<minSeverity>1</minSeverity>
				<label>adaptive armor (active)</label>
				<statOffsets>
					<MoveSpeed>0.25</MoveSpeed>
				</statOffsets>
			</li>
			<li>
				<minSeverity>2</minSeverity>
				<label>adaptive armor (alert)</label>
				<statOffsets>
					<MoveSpeed>0.0625</MoveSpeed>
					<ArmorRating_Blunt>0.3125</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.3125</ArmorRating_Sharp>
				</statOffsets>
			</li>
			<li>
				<minSeverity>3</minSeverity>
				<label>adaptive armor (defensive)</label>
				<statOffsets>
					<MoveSpeed>-0.125</MoveSpeed>
					<ArmorRating_Blunt>0.625</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.625</ArmorRating_Sharp>
				</statOffsets>
			</li>
			<li>
				<minSeverity>4</minSeverity>
				<label>adaptive armor (emergency)</label>
				<statOffsets>
					<MoveSpeed>-0.3125</MoveSpeed>
					<ArmorRating_Blunt>0.9375</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.9375</ArmorRating_Sharp>
				</statOffsets>
			</li>
			<li>
				<minSeverity>5</minSeverity>
				<label>adaptive armor (fortress)</label>
				<statOffsets>
					<MoveSpeed>-0.75</MoveSpeed>
					<ArmorRating_Blunt>1.25</ArmorRating_Blunt>
					<ArmorRating_Sharp>1.25</ArmorRating_Sharp>
				</statOffsets>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>transcendence_battle_morph_verbs</defName>
		<hediffClass>HediffWithComps</hediffClass>
		<label>transcendent battle-morph protocol</label>
		<description>A permanent nanite combat protocol that emulates battle-morph limbs without replacing natural body parts. It continuously provides all battle-morph maneuvers for arm, hand, and leg strike patterns.</description>
		<defaultLabelColor>(192,192,192)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="EasyMode.HediffCompProperties_VerbGiverProfiled">
				<verbToolProfileDef>TranscendenceBattleMorphToolset</verbToolProfileDef>
			</li>
		</comps>
	</HediffDef>
	<Def Class="EasyMode.VerbToolProfileDef">
		<defName>TranscendenceBattleMorphToolset</defName>
		<tools>
			<li>
				<label>phase cleave</label>
				<capacities>
					<li>Cut</li>
				</capacities>
				<armorPenetration>2.25</armorPenetration>
				<power>25</power>
				<cooldownTime>1.2</cooldownTime>
			</li>
			<li>
				<label>kinetic ram</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<armorPenetration>1.95</armorPenetration>
				<power>9.0</power>
				<cooldownTime>1.5</cooldownTime>
			</li>
			<li>
				<label>vector thrust</label>
				<capacities>
					<li>Stab</li>
				</capacities>
				<armorPenetration>3.35</armorPenetration>
				<power>36.8</power>
				<cooldownTime>2.1</cooldownTime>
			</li>
			<li>
				<label>needle rake</label>
				<capacities>
					<li>Scratch</li>
				</capacities>
				<armorPenetration>1.05</armorPenetration>
				<power>5.2</power>
				<cooldownTime>0.2</cooldownTime>
			</li>
			<li>
				<label>heel spike</label>
				<capacities>
					<li>Stab</li>
				</capacities>
				<armorPenetration>2.10</armorPenetration>
				<power>7.2</power>
				<cooldownTime>1.3</cooldownTime>
			</li>
			<li>
				<label>sweeping kick</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<armorPenetration>0.85</armorPenetration>
				<power>8.4</power>
				<cooldownTime>0.6</cooldownTime>
			</li>
		</tools>
	</Def>
	<Def Class="EasyMode.ConditionalHediffProfileDef">
		<defName>EM_NexusSpine_CoreProfile</defName>
		<rules>
			<li>
				<key>core-physical</key>
				<activeHediff>transcendence_physical</activeHediff>
				<activeSeverity>1</activeSeverity>
			</li>
			<li>
				<key>core-biological</key>
				<activeHediff>transcendence_biological</activeHediff>
				<activeSeverity>1</activeSeverity>
			</li>
		</rules>
	</Def>

	<HediffDef>
		<defName>EM_NexusSpine_RangedAdaptation</defName>
		<hediffClass>HediffWithComps</hediffClass>
		<label>nexus ranged calibration</label>
		<description>The adaptive nexus spine has detected a ranged weapon and is continuously recalibrating posture, recoil compensation, and visual-motor timing.</description>
		<defaultLabelColor>(120,200,255)</defaultLabelColor>
		<isBad>false</isBad>
		<stages>
			<li>
				<statFactors>
					<ShootingAccuracyPawn>1.35</ShootingAccuracyPawn>
					<AimingDelayFactor>0.70</AimingDelayFactor>
					<RangedCooldownFactor>0.80</RangedCooldownFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>

	<HediffDef>
		<defName>EM_NexusSpine_GeneAdaptation</defName>
		<hediffClass>HediffWithComps</hediffClass>
		<label>nexus genetic resonance</label>
		<description>The adaptive nexus spine is resonating with strong fast-twitch muscle genes, reinforcing the host's close-combat biomechanics.</description>
		<defaultLabelColor>(170,120,255)</defaultLabelColor>
		<isBad>false</isBad>
		<stages>
			<li>
				<statFactors>
					<MeleeDamageFactor>1.35</MeleeDamageFactor>
					<MeleeArmorPenetration>1.25</MeleeArmorPenetration>
					<MeleeCooldownFactor>0.85</MeleeCooldownFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>

	<HediffDef ParentName="AddedBodyPartBase">
		<defName>EM_AdaptiveNexusSpine</defName>
		<label>adaptive nexus spine</label>
		<labelNoun>an adaptive nexus spine</labelNoun>
		<description>An installed synthetic spine built around a self-reconfiguring neural lattice. It acts as a body-wide adaptation controller, distributing enhancement protocols and changing modules in response to the host's condition, actions, genes, and equipment.</description>
		<descriptionHyperlinks><ThingDef>EM_AdaptiveNexusSpine</ThingDef></descriptionHyperlinks>
		<spawnThingOnRemoved>EM_AdaptiveNexusSpine</spawnThingOnRemoved>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.35</partEfficiency>
			<betterThanNatural>true</betterThanNatural>
		</addedPartProps>
		<comps>
			<li Class="EasyMode.HediffCompProperties_ConditionalHediffDistributor">
				<checkIntervalTicks>120</checkIntervalTicks>
				<profiles>
					<li>EM_NexusSpine_CoreProfile</li>
				</profiles>
				<rules>
					<li>
						<key>health-adaptive-armor</key>
						<activeHediff>adaptive_armor</activeHediff>
						<activeSeverity>1</activeSeverity>
						<healthPercent>0~0.75</healthPercent>
					</li>

					<li>
						<key>combat-battle-morph</key>
						<activeHediff>transcendence_battle_morph_verbs</activeHediff>
						<activeSeverity>1</activeSeverity>
						<inCombat>Required</inCombat>
					</li>

					<li>
						<key>equipment-ranged-calibration</key>
						<activeHediff>EM_NexusSpine_RangedAdaptation</activeHediff>
						<activeSeverity>1</activeSeverity>
						<anyEquipmentTags>
							<li>Ranged</li>
						</anyEquipmentTags>
					</li>

					<li MayRequire="Ludeon.RimWorld.Biotech">
						<key>gene-strong-melee</key>
						<activeHediff>EM_NexusSpine_GeneAdaptation</activeHediff>
						<activeSeverity>1</activeSeverity>
						<allGenes>
							<li>MeleeDamage_Strong</li>
						</allGenes>
					</li>
				</rules>
			</li>
		</comps>
	</HediffDef>
</Defs>
