<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<HediffDef>
		<defName>transcendence</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>transcendence</label>
		<description>Advanced glitter tech mechanites have fundamentally transformed the body, elevating it beyond mortal limitations. Every biological system operates at peak efficiency while the mind achieves perfect clarity.</description>
		<defaultLabelColor>(192,192,192)</defaultLabelColor>
		<scenarioCanAdd>true</scenarioCanAdd>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="EasyMode.HediffCompProperties_GiveMultipleHediffs">
				<atSeverity>0</atSeverity>
				<disappearsAfterGiving>false</disappearsAfterGiving>
				<hediffsToGive>
					<li>
						<hediffDef>transcendence_cognitive</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>transcendence_physical</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>transcendence_biological</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>transcendence_environmental</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>transcendence_psychic</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>adaptive_armor</hediffDef>
						<severity>1.0</severity>
					</li>
				</hediffsToGive>
			</li>
		</comps>
	</HediffDef>
	<HediffDef>
		<defName>transcendence_cognitive</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>cognitive enhancement</label>
		<description>Enhanced mental capabilities from mechanite integration.</description>
		<defaultLabelColor>(192,192,192)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>1.20</offset>
					</li>
					<li>
						<capacity>Sight</capacity>
						<offset>0.25</offset>
					</li>
				</capMods>
				<statFactors>
					<MeleeCooldownFactor>0.6</MeleeCooldownFactor>
					<MeleeHitChance>1.4</MeleeHitChance>
					<MeleeArmorPenetration>1.6</MeleeArmorPenetration>
					<MeleeDamageFactor>1.5</MeleeDamageFactor>
					<MeleeDodgeChance>1.6</MeleeDodgeChance>
					<RangedCooldownFactor>0.4</RangedCooldownFactor>
					<ShootingAccuracyPawn>1.8</ShootingAccuracyPawn>
					<AimingDelayFactor>0.4</AimingDelayFactor>
					<StudyEfficiency>2</StudyEfficiency>
					<WorkSpeedGlobalOffsetMech>2</WorkSpeedGlobalOffsetMech>
					<GlobalLearningFactor>2</GlobalLearningFactor>
					<WorkSpeedGlobal>2</WorkSpeedGlobal>
					<NegotiationAbility>2</NegotiationAbility>
					<ResearchSpeed>2</ResearchSpeed>
					<ConversionPower>2</ConversionPower>
					<SocialImpact>2</SocialImpact>
					<TradePriceImprovement>2</TradePriceImprovement>
					<GeneralLaborSpeed>2</GeneralLaborSpeed>
				</statFactors>
				<painFactor>0</painFactor>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>transcendence_physical</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>physical enhancement</label>
		<description>Enhanced physical capabilities from mechanite integration.</description>
		<defaultLabelColor>(192,192,192)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>Moving</capacity>
						<offset>0.15</offset>
					</li>
					<li>
						<capacity>Manipulation</capacity>
						<offset>0.20</offset>
					</li>
				</capMods>
				<statOffsets>
					<PawnBeauty>3</PawnBeauty>
					<MechBandwidth>12</MechBandwidth>
					<MoveSpeed>0.2</MoveSpeed>
					<CarryingCapacity>25</CarryingCapacity>
					<ArmorRating_Blunt>0.2</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.2</ArmorRating_Sharp>
					<ArmorRating_Heat>2</ArmorRating_Heat>
				</statOffsets>
				<statFactors>
					<MoveSpeed>1.25</MoveSpeed>
					<IncomingDamageFactor>0.2</IncomingDamageFactor>
					<StaggerDurationFactor>0</StaggerDurationFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>transcendence_biological</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>biological enhancement</label>
		<description>Enhanced biological systems from mechanite integration.</description>
		<defaultLabelColor>(192,192,192)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="HediffCompProperties_GiveAbility">
				<abilityDefs>
					<li>ResurrectNoCost</li>
					<li>TranscendentSelfTeleport</li>
					<li>TranscendentDropPods</li>
				</abilityDefs>
			</li>
			<li Class="HediffCompProperties_HealPermanentWounds" />
		</comps>
		<preventsDeath>true</preventsDeath>
		<keepOnBodyPartRestoration>True</keepOnBodyPartRestoration>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>BloodFiltration</capacity>
						<offset>0.90</offset>
					</li>
					<li>
						<capacity>BloodPumping</capacity>
						<offset>0.25</offset>
					</li>
					<li>
						<capacity>Metabolism</capacity>
						<offset>0.30</offset>
					</li>
					<li>
						<capacity>Breathing</capacity>
						<offset>0.20</offset>
					</li>
				</capMods>
				<regeneration>70</regeneration>
				<disablesNeeds>
					<li>Rest</li>
					<li>Comfort</li>
					<li>Joy</li>
					<li>Food</li>
					<li>Mood</li>
					<li>Beauty</li>
					<li>Outdoors</li>
					<li>Indoors</li>
				</disablesNeeds>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>transcendence_environmental</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>environmental adaptation</label>
		<description>Enhanced resistance to environmental hazards from mechanite integration.</description>
		<defaultLabelColor>(192,192,192)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<statOffsets>
					<VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">1.2</VacuumResistance>
					<ComfyTemperatureMin>-250</ComfyTemperatureMin>
					<ComfyTemperatureMax>250</ComfyTemperatureMax>
					<Flammability>-1.2</Flammability>
					<ToxicResistance>1</ToxicResistance>
				</statOffsets>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>transcendence_psychic</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>psychic enhancement</label>
		<description>Enhanced psychic capabilities from mechanite integration.</description>
		<defaultLabelColor>(192,192,192)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="EasyMode.HediffCompProperties_RestorePsy" />
		</comps>
		<stages>
			<li>
				<statFactors>
					<PsychicSensitivity>10</PsychicSensitivity>
					<MeditationFocusGain>10</MeditationFocusGain>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>psylink_fullpower</defName>
		<hediffClass>Hediff_Psylink</hediffClass>
		<label>psylink level 6</label>
		<description>A psylink with the highest level of psychic capability.</description>
		<scenarioCanAdd>true</scenarioCanAdd>
		<isBad>false</isBad>
		<defaultLabelColor>(128,0,255)</defaultLabelColor>
		<priceImpact>false</priceImpact>
		<initialSeverity>6</initialSeverity>
		<minSeverity>0</minSeverity>
		<maxSeverity>6</maxSeverity>
		<keepOnBodyPartRestoration>True</keepOnBodyPartRestoration>
		<stages>
			<li>
				<minSeverity>1</minSeverity>
				<statFactors>
					<PsychicEntropyMax>1.0</PsychicEntropyMax>
					<PsychicEntropyRecoveryRate>1</PsychicEntropyRecoveryRate>
				</statFactors>
			</li>
			<li>
				<minSeverity>2</minSeverity>
				<statFactors>
					<PsychicEntropyMax>1.3334</PsychicEntropyMax>
					<PsychicEntropyRecoveryRate>1.125</PsychicEntropyRecoveryRate>
				</statFactors>
			</li>
			<li>
				<minSeverity>3</minSeverity>
				<statFactors>
					<PsychicEntropyMax>1.6667</PsychicEntropyMax>
					<PsychicEntropyRecoveryRate>1.25</PsychicEntropyRecoveryRate>
				</statFactors>
			</li>
			<li>
				<minSeverity>4</minSeverity>
				<statFactors>
					<PsychicEntropyMax>2.0</PsychicEntropyMax>
					<PsychicEntropyRecoveryRate>1.375</PsychicEntropyRecoveryRate>
				</statFactors>
			</li>
			<li>
				<minSeverity>5</minSeverity>
				<statFactors>
					<PsychicEntropyMax>2.3334</PsychicEntropyMax>
					<PsychicEntropyRecoveryRate>1.5</PsychicEntropyRecoveryRate>
				</statFactors>
			</li>
			<li>
				<minSeverity>6</minSeverity>
				<statFactors>
					<PsychicEntropyMax>2.6667</PsychicEntropyMax>
					<PsychicEntropyRecoveryRate>1.625</PsychicEntropyRecoveryRate>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>adaptive_armor</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>adaptive armor</label>
		<description>Advanced adaptive armor that responds to the wearer's health condition. As health decreases, the armor becomes more protective but restricts movement.</description>
		<defaultLabelColor>(100,100,100)</defaultLabelColor>
		<scenarioCanAdd>true</scenarioCanAdd>
		<maxSeverity>5.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="EasyMode.HediffCompProperties_AdaptiveArmor"></li>
		</comps>
		<stages>
			<li>
				<minSeverity>1</minSeverity>
				<label>adaptive armor (active)</label>
				<statOffsets>
					<MoveSpeed>0.25</MoveSpeed>
				</statOffsets>
			</li>
			<li>
				<minSeverity>2</minSeverity>
				<label>adaptive armor (alert)</label>
				<statOffsets>
					<MoveSpeed>0.0625</MoveSpeed>
					<ArmorRating_Blunt>0.3125</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.3125</ArmorRating_Sharp>
				</statOffsets>
			</li>
			<li>
				<minSeverity>3</minSeverity>
				<label>adaptive armor (defensive)</label>
				<statOffsets>
					<MoveSpeed>-0.125</MoveSpeed>
					<ArmorRating_Blunt>0.625</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.625</ArmorRating_Sharp>
				</statOffsets>
			</li>
			<li>
				<minSeverity>4</minSeverity>
				<label>adaptive armor (emergency)</label>
				<statOffsets>
					<MoveSpeed>-0.3125</MoveSpeed>
					<ArmorRating_Blunt>0.9375</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.9375</ArmorRating_Sharp>
				</statOffsets>
			</li>
			<li>
				<minSeverity>5</minSeverity>
				<label>adaptive armor (fortress)</label>
				<statOffsets>
					<MoveSpeed>-0.75</MoveSpeed>
					<ArmorRating_Blunt>1.25</ArmorRating_Blunt>
					<ArmorRating_Sharp>1.25</ArmorRating_Sharp>
				</statOffsets>
			</li>
		</stages>
	</HediffDef>
</Defs>
