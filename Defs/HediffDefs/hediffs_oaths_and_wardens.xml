		<defaultLabelColor>(212,175,55)</defaultLabelColor>
		<scenarioCanAdd>true</scenarioCanAdd>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="EasyMode.HediffCompProperties_GiveMultipleHediffs">
				<atSeverity>0</atSeverity>
				<disappearsAfterGiving>false</disappearsAfterGiving>
				<hediffsToGive>
					<li>
						<hediffDef>archotechoath_cognition</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>archotechoath_industry</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>archotechoath_command</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>archotechoath_aegis</hediffDef>
						<severity>1.0</severity>
					</li>
				</hediffsToGive>
			</li>
		</comps>
	</HediffDef>
