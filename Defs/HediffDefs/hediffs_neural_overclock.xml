<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<HediffDef>
		<defName>EasyMode_NeuralOverclock</defName>
		<label>neural overclock</label>
		<description>The nervous system and musculature are operating far beyond normal safety limits. Motion becomes explosively fast and precise while accumulating tissue strain across the body.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<isBad>false</isBad>
		<maxSeverity>1</maxSeverity>
		<comps>
			<li Class="EasyMode.HediffCompProperties_NeuralOverclock">
				<damageIntervalTicks>60</damageIntervalTicks>
				<damageRange>1~2</damageRange>
				<internalPartChance>0.01</internalPartChance>
				<trailSampleIntervalTicks>4</trailSampleIntervalTicks>
				<trailLifetimeTicks>20</trailLifetimeTicks>
				<maxTrailSnapshots>5</maxTrailSnapshots>
			</li>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>300</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
			</li>
			<li Class="HediffCompProperties_DisappearsOnDeath" />
		</comps>
		<stages>
			<li>
				<statFactors>
					<MoveSpeed>4.5</MoveSpeed>
					<MeleeHitChance>1.5</MeleeHitChance>
					<AimingDelayFactor>0.35</AimingDelayFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>

	<HediffDef ParentName="InjuryBase">
		<defName>EasyMode_NeuralOverclockStrain</defName>
		<label>overclock strain</label>
		<labelNoun>an overclock strain</labelNoun>
		<description>Localized neural and muscular damage caused by forcing the body beyond its safe operating limits.</description>
		<displayWound>false</displayWound>
		<comps>
			<li Class="HediffCompProperties_TendDuration">
				<labelTendedWell>stabilized</labelTendedWell>
				<labelTendedWellInner>stabilized</labelTendedWellInner>
				<labelSolidTendedWell>stabilized</labelSolidTendedWell>
			</li>
		</comps>
		<injuryProps>
			<painPerSeverity>0.006</painPerSeverity>
			<bleedRate>0</bleedRate>
			<canMerge>true</canMerge>
			<destroyedLabel>Overstrained</destroyedLabel>
			<destroyedOutLabel>Overstrained</destroyedOutLabel>
		</injuryProps>
	</HediffDef>
</Defs>
