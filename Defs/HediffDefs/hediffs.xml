<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<HediffDef>
		<defName>nanorecreate</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>recreate</label>
		<description>Active glitter tech mechanites in the body. They improve the body's functioning
			in
			all respects.</description>
		<defaultLabelColor>(192,150,64)</defaultLabelColor>
		<scenarioCanAdd>true</scenarioCanAdd>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="HediffCompProperties_HealPermanentWounds" />
			<li Class="HediffCompProperties_GiveAbility">
				<abilityDefs>
					<li>imbafarskip</li>
				</abilityDefs>
			</li>
		</comps>
		<preventsDeath>true</preventsDeath>
		<keepOnBodyPartRestoration>
			True
		</keepOnBodyPartRestoration>
		<stages>
			<li>
				<painFactor>0.5</painFactor>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>1.20</offset>
					</li>
					<li>
						<capacity>Moving</capacity>
						<offset>0.15</offset>
					</li>
					<li>
						<capacity>Sight</capacity>
						<offset>0.25</offset>
					</li>
					<li>
						<capacity>BloodFiltration</capacity>
						<offset>0.90</offset>
					</li>
					<li>
						<capacity>BloodPumping</capacity>
						<offset>0.25</offset>
					</li>
					<li>
						<capacity>Metabolism</capacity>
						<offset>0.30</offset>
					</li>
					<li>
						<capacity>Breathing</capacity>
						<offset>0.20</offset>
					</li>
				</capMods>
				<regeneration>70</regeneration>
				<disablesNeeds>
					<li>Rest</li>
					<li>Comfort</li>
					<li>Joy</li>
					<li>Food</li>
					<li>Mood</li>
					<li>Beauty</li>
					<li>Outdoors</li>
				</disablesNeeds>
				<statOffsets>
					<MechBandwidth>12</MechBandwidth>
					<VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">1.2</VacuumResistance>
					<ComfyTemperatureMin>-250</ComfyTemperatureMin>
					<ComfyTemperatureMax>250</ComfyTemperatureMax>
				</statOffsets>
				<statFactors>
					<StudyEfficiency>4</StudyEfficiency>
					<PsychicSensitivity>10</PsychicSensitivity>
					<WorkSpeedGlobalOffsetMech>4</WorkSpeedGlobalOffsetMech>
				</statFactors>
			</li>
		</stages>
	</HediffDef>

