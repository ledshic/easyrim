<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <HediffDef>
    <defName>transcendence</defName>
    <hediffClass>Hediff_High</hediffClass>
    <label>transcendence</label>
    <description>
      Advanced glitter tech mechanites have fundamentally transformed the body, elevating it beyond mortal limitations. Every biological system operates at peak efficiency while the mind achieves perfect clarity.
    </description>
    <defaultLabelColor>(192,150,64)</defaultLabelColor>
    <scenarioCanAdd>true</scenarioCanAdd>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <comps>
      <li Class="HediffCompProperties_HealPermanentWounds" />
      <li Class="HediffCompProperties_GiveHediff">
        <hediffDef>transcendence_cognitive</hediffDef>
        <atSeverity>1</atSeverity>
        <disappearsAfterGiving>false</disappearsAfterGiving>
      </li>
      <li Class="HediffCompProperties_SeverityPerSecond">
        <severityPerSecondRange>0.5</severityPerSecondRange>
      </li>
    </comps>
    <preventsDeath>true</preventsDeath>
    <keepOnBodyPartRestoration> True </keepOnBodyPartRestoration>
  </HediffDef>

  <HediffDef>
    <defName>bravesoul</defName>
    <hediffClass>Hediff_High</hediffClass>
    <label>brave soul</label>
    <description>
      An immortal warrior's spirit burns within, forged through countless battles. Death itself bends to their indomitable will, and their combat prowess transcends mortal limitations.
    </description>
    <defaultLabelColor>(0,206,209)</defaultLabelColor>
    <scenarioCanAdd>true</scenarioCanAdd>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <stages>
      <li>
        <painFactor>0.1</painFactor>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>0.30</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>0.40</offset>
          </li>
          <li>
            <capacity>Sight</capacity>
            <offset>0.35</offset>
          </li>
          <li>
            <capacity>BloodFiltration</capacity>
            <offset>0.50</offset>
          </li>
          <li>
            <capacity>BloodPumping</capacity>
            <offset>0.60</offset>
          </li>
          <li>
            <capacity>Metabolism</capacity>
            <offset>0.40</offset>
          </li>
          <li>
            <capacity>Breathing</capacity>
            <offset>0.30</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>0.50</offset>
          </li>
        </capMods>
        <regeneration>150</regeneration>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>pioneerspirit</defName>
    <hediffClass>Hediff_High</hediffClass>
    <label>pioneer spirit</label>
    <description>
      The essence of exploration and discovery flows through their veins. Born to chart the unknown, they possess an otherworldly connection to the wilderness and an innate mastery over all forms of labor and combat.
    </description>
    <defaultLabelColor>(135,206,235)</defaultLabelColor>
    <scenarioCanAdd>true</scenarioCanAdd>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <stages>
      <li>
        <painFactor>0.3</painFactor>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>0.25</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>0.50</offset>
          </li>
          <li>
            <capacity>Sight</capacity>
            <offset>0.40</offset>
          </li>
          <li>
            <capacity>BloodFiltration</capacity>
            <offset>0.35</offset>
          </li>
          <li>
            <capacity>BloodPumping</capacity>
            <offset>0.30</offset>
          </li>
          <li>
            <capacity>Metabolism</capacity>
            <offset>0.35</offset>
          </li>
          <li>
            <capacity>Breathing</capacity>
            <offset>0.25</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>0.45</offset>
          </li>
        </capMods>
        <regeneration>40</regeneration>
        <statOffsets>
          <MoveSpeed>2.0</MoveSpeed>
          <CarryingCapacity>200</CarryingCapacity>
          <ShootingAccuracyPawn>15</ShootingAccuracyPawn>
          <MiningSpeed>3.0</MiningSpeed>
        </statOffsets>
        <statFactors>
          <WorkSpeedGlobal>4</WorkSpeedGlobal>
          <GlobalLearningFactor>3</GlobalLearningFactor>
          <MoveSpeed>2.5</MoveSpeed>
          <MiningYield>4</MiningYield>
          <PlantHarvestYield>4</PlantHarvestYield>
          <RangedCooldownFactor>0.15</RangedCooldownFactor>
          <AimingDelayFactor>0.2</AimingDelayFactor>
          <IncomingDamageFactor>0.4</IncomingDamageFactor>
          <ResearchSpeed>3</ResearchSpeed>
        </statFactors>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>transcendence_cognitive</defName>
    <hediffClass>Hediff_High</hediffClass>
    <label>cognitive enhancement</label>
    <description>
      Enhanced mental capabilities from mechanite integration.
    </description>
    <defaultLabelColor>(192,150,64)</defaultLabelColor>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <comps>
      <li Class="HediffCompProperties_GiveHediff">
        <hediffDef>transcendence_physical</hediffDef>
        <atSeverity>1</atSeverity>
        <disappearsAfterGiving>false</disappearsAfterGiving>
      </li>
    </comps>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>1.20</offset>
          </li>
          <li>
            <capacity>Sight</capacity>
            <offset>0.25</offset>
          </li>
        </capMods>
        <statOffsets>
          <PawnBeauty>3</PawnBeauty>
          <MentalBreakThreshold>-1</MentalBreakThreshold>
        </statOffsets>
        <statFactors>
          <StudyEfficiency>4</StudyEfficiency>
          <WorkSpeedGlobalOffsetMech>4</WorkSpeedGlobalOffsetMech>
          <GlobalLearningFactor>2</GlobalLearningFactor>
          <WorkSpeedGlobal>2</WorkSpeedGlobal>
          <NegotiationAbility>2</NegotiationAbility>
          <ResearchSpeed>2</ResearchSpeed>
          <ConversionPower>2</ConversionPower>
          <SocialImpact>2</SocialImpact>
          <TradePriceImprovement>2</TradePriceImprovement>
          <GeneralLaborSpeed>2</GeneralLaborSpeed>
        </statFactors>
        <painFactor>0</painFactor>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>transcendence_physical</defName>
    <hediffClass>Hediff_High</hediffClass>
    <label>physical enhancement</label>
    <description>
      Enhanced physical capabilities from mechanite integration.
    </description>
    <defaultLabelColor>(192,150,64)</defaultLabelColor>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <comps>
      <li Class="HediffCompProperties_GiveHediff">
        <hediffDef>transcendence_biological</hediffDef>
        <atSeverity>1</atSeverity>
        <disappearsAfterGiving>false</disappearsAfterGiving>
      </li>
    </comps>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Moving</capacity>
            <offset>0.15</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>0.20</offset>
          </li>
        </capMods>
        <statOffsets>
          <MechBandwidth>12</MechBandwidth>
          <MoveSpeed>0.2</MoveSpeed>
          <CarryingCapacity>25</CarryingCapacity>
          <ArmorRating_Blunt>0.2</ArmorRating_Blunt>
          <ArmorRating_Sharp>0.2</ArmorRating_Sharp>
          <ArmorRating_Heat>2</ArmorRating_Heat>
        </statOffsets>
        <statFactors>
          <MoveSpeed>1.25</MoveSpeed>
          <IncomingDamageFactor>0.2</IncomingDamageFactor>
        </statFactors>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>transcendence_biological</defName>
    <hediffClass>Hediff_High</hediffClass>
    <label>biological enhancement</label>
    <description>
      Enhanced biological systems from mechanite integration.
    </description>
    <defaultLabelColor>(192,150,64)</defaultLabelColor>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <comps>
      <li Class="HediffCompProperties_GiveHediff">
        <hediffDef>transcendence_environmental</hediffDef>
        <atSeverity>1</atSeverity>
        <disappearsAfterGiving>false</disappearsAfterGiving>
      </li>
      <li Class="HediffCompProperties_GiveAbility">
        <abilityDefs>
          <li>ResurrectNoCost</li>
        </abilityDefs>
      </li>
    </comps>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>BloodFiltration</capacity>
            <offset>0.90</offset>
          </li>
          <li>
            <capacity>BloodPumping</capacity>
            <offset>0.25</offset>
          </li>
          <li>
            <capacity>Metabolism</capacity>
            <offset>0.30</offset>
          </li>
          <li>
            <capacity>Breathing</capacity>
            <offset>0.20</offset>
          </li>
        </capMods>
        <regeneration>70</regeneration>
        <disablesNeeds>
          <li>Rest</li>
          <li>Comfort</li>
          <li>Joy</li>
          <li>Food</li>
          <li>Mood</li>
          <li>Beauty</li>
          <li>Outdoors</li>
        </disablesNeeds>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>transcendence_environmental</defName>
    <hediffClass>Hediff_High</hediffClass>
    <label>environmental adaptation</label>
    <description>
      Enhanced resistance to environmental hazards from mechanite integration.
    </description>
    <defaultLabelColor>(192,150,64)</defaultLabelColor>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <comps>
      <li Class="HediffCompProperties_GiveHediff">
        <hediffDef>transcendence_psychic</hediffDef>
        <atSeverity>1</atSeverity>
        <disappearsAfterGiving>false</disappearsAfterGiving>
      </li>
      <li Class="HediffCompProperties_GiveAbility">
        <abilityDefs>
          <li>TranscendentDropPods</li>
        </abilityDefs>
      </li>
    </comps>
    <stages>
      <li>
        <statOffsets>
          <VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">1.2</VacuumResistance>
          <ComfyTemperatureMin>-250</ComfyTemperatureMin>
          <ComfyTemperatureMax>250</ComfyTemperatureMax>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>transcendence_psychic</defName>
    <hediffClass>Hediff_High</hediffClass>
    <label>psychic enhancement</label>
    <description>
      Enhanced psychic capabilities from mechanite integration.
    </description>
    <defaultLabelColor>(192,150,64)</defaultLabelColor>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <comps>
      <li Class="HediffCompProperties_GiveAbility">
        <abilityDefs>
          <li>imbafarskip</li>
        </abilityDefs>
      </li>
    </comps>
    <stages>
      <li>
        <statFactors>
          <PsychicSensitivity>10</PsychicSensitivity>
          <MeditationFocusGain>10</MeditationFocusGain>
        </statFactors>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>psylink_fullpower</defName>
    <hediffClass>Hediff_Psylink</hediffClass>
    <label>psylink level 6</label>
    <description>
      A psylink with the highest level of psychic capability.
    </description>
    <scenarioCanAdd>true</scenarioCanAdd>
    <isBad>false</isBad>
    <defaultLabelColor>(128,0,255)</defaultLabelColor>
    <priceImpact>false</priceImpact>
    <initialSeverity>6</initialSeverity>
    <minSeverity>0</minSeverity>
    <maxSeverity>6</maxSeverity>
    <keepOnBodyPartRestoration>True</keepOnBodyPartRestoration>
    <comps>
      <li Class="HediffCompProperties_SeverityPerSecond">
        <severityPerSecondRange>1</severityPerSecondRange>
      </li>
    </comps>
    <stages>
      <li>
        <minSeverity>1</minSeverity>
        <statFactors>
          <PsychicEntropyMax>1.0</PsychicEntropyMax>
          <PsychicEntropyRecoveryRate>1</PsychicEntropyRecoveryRate>
        </statFactors>
      </li>
      <li>
        <minSeverity>2</minSeverity>
        <statFactors>
          <PsychicEntropyMax>1.3334</PsychicEntropyMax>
          <PsychicEntropyRecoveryRate>1.125</PsychicEntropyRecoveryRate>
        </statFactors>
      </li>
      <li>
        <minSeverity>3</minSeverity>
        <statFactors>
          <PsychicEntropyMax>1.6667</PsychicEntropyMax>
          <PsychicEntropyRecoveryRate>1.25</PsychicEntropyRecoveryRate>
        </statFactors>
      </li>
      <li>
        <minSeverity>4</minSeverity>
        <statFactors>
          <PsychicEntropyMax>2.0</PsychicEntropyMax>
          <PsychicEntropyRecoveryRate>1.375</PsychicEntropyRecoveryRate>
        </statFactors>
      </li>
      <li>
        <minSeverity>5</minSeverity>
        <statFactors>
          <PsychicEntropyMax>2.3334</PsychicEntropyMax>
          <PsychicEntropyRecoveryRate>1.5</PsychicEntropyRecoveryRate>
        </statFactors>
      </li>
      <li>
        <minSeverity>6</minSeverity>
        <statFactors>
          <PsychicEntropyMax>2.6667</PsychicEntropyMax>
          <PsychicEntropyRecoveryRate>1.625</PsychicEntropyRecoveryRate>
        </statFactors>
      </li>
    </stages>
  </HediffDef>
</Defs>
