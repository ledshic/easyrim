<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <HediffDef>
    <defName>WorkMotivation</defName>
    <hediffClass>HediffWithComps</hediffClass>
    <label>united as one</label>
    <description>Inspired by a rallying call, this pawn works with exceptional drive and focus. All tasks are performed faster while the motivation holds.</description>
    <defaultLabelColor>(255,215,0)</defaultLabelColor>
    <isBad>false</isBad>
    <maxSeverity>1.0</maxSeverity>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>60000</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
    <stages>
      <li>
        <statOffsets>
          <WorkSpeedGlobal>0.75</WorkSpeedGlobal>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>
</Defs>
