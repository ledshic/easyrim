<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<HediffDef>
		<defName>crimsondynasty</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>crimson dynasty</label>
		<description>An ancient hemogenic lineage has awakened in the host. Core bloodline channels remain active at all times, and blood essence resonance is conditionally granted when the host carries the Hemogenic gene. The resonance stage then shifts dynamically with current blood state.</description>
		<defaultLabelColor>(178,34,34)</defaultLabelColor>
		<scenarioCanAdd>true</scenarioCanAdd>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="HediffCompProperties_GiveAbility">
				<abilityDefs>
					<li>CrimsonBloodrush</li>
					<li>CrimsonSovereignGaze</li>
				</abilityDefs>
			</li>
			<li Class="EasyMode.HediffCompProperties_GiveMultipleHediffs">
				<atSeverity>0</atSeverity>
				<disappearsAfterGiving>false</disappearsAfterGiving>
				<hediffsToGive>
					<li>
						<hediffDef>crimsondynasty_predator</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>crimsondynasty_hemogenic</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>crimsondynasty_mesmer</hediffDef>
						<severity>1.0</severity>
					</li>
					<li>
						<hediffDef>crimsondynasty_dreadguard</hediffDef>
						<severity>1.0</severity>
					</li>
				</hediffsToGive>
			</li>
			<li Class="EasyMode.HediffCompProperties_ConditionalHediffDistributor">
				<checkIntervalTicks>90</checkIntervalTicks>
				<rules>
					<li>
						<key>crimson-blood-resonance-gene</key>
						<activeHediff>bloodhemogen_resonance</activeHediff>
						<activeSeverity>-1</activeSeverity>
						<allGenes>
							<li>Hemogenic</li>
						</allGenes>
					</li>
					<li>
						<key>crimson-bloodfrenzy</key>
						<activeHediff>crimsondynasty_bloodfrenzy</activeHediff>
						<activeSeverity>1.0</activeSeverity>
						<healthPercent>0~0.45</healthPercent>
						<inCombat>Required</inCombat>
					</li>
					<li>
						<key>crimson-noble-poise</key>
						<activeHediff>crimsondynasty_noble_poise</activeHediff>
						<activeSeverity>1.0</activeSeverity>
						<healthPercent>0.8~1</healthPercent>
						<inCombat>Forbidden</inCombat>
					</li>
					<li>
						<key>crimson-duelist-ascendancy</key>
						<activeHediff>crimsondynasty_duelist_ascendancy</activeHediff>
						<activeSeverity>1.0</activeSeverity>
						<anyEquipmentTags>
							<li>Melee</li>
						</anyEquipmentTags>
						<inCombat>Required</inCombat>
					</li>
				</rules>
			</li>
		</comps>
	</HediffDef>
	<HediffDef>
		<defName>crimsondynasty_bloodfrenzy</defName>
		<hediffClass>HediffWithComps</hediffClass>
		<label>bloodfrenzy ascendant</label>
		<description>At the edge of death, hunger and terror collapse into a monstrous battle crescendo.</description>
		<defaultLabelColor>(178,34,34)</defaultLabelColor>
		<isBad>false</isBad>
		<stages>
			<li>
				<painFactor>0.1</painFactor>
				<regeneration>95</regeneration>
				<statFactors>
					<MeleeDamageFactor>1.75</MeleeDamageFactor>
					<MeleeCooldownFactor>0.5</MeleeCooldownFactor>
					<MeleeHitChance>1.45</MeleeHitChance>
					<MeleeDodgeChance>1.35</MeleeDodgeChance>
					<MoveSpeed>1.35</MoveSpeed>
					<IncomingDamageFactor>1.18</IncomingDamageFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>crimsondynasty_noble_poise</defName>
		<hediffClass>HediffWithComps</hediffClass>
		<label>noble poise</label>
		<description>When well-fed and unpressured, aristocratic control sharpens social coercion and colony-level command.</description>
		<defaultLabelColor>(178,34,34)</defaultLabelColor>
		<isBad>false</isBad>
		<stages>
			<li>
				<statFactors>
					<SocialImpact>1.6</SocialImpact>
					<NegotiationAbility>1.45</NegotiationAbility>
					<TradePriceImprovement>1.3</TradePriceImprovement>
					<WorkSpeedGlobal>1.25</WorkSpeedGlobal>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>crimsondynasty_duelist_ascendancy</defName>
		<hediffClass>HediffWithComps</hediffClass>
		<label>duelist ascendancy</label>
		<description>Melee engagement unlocks predatory duelist routines focused on pressure and execution.</description>
		<defaultLabelColor>(178,34,34)</defaultLabelColor>
		<isBad>false</isBad>
		<stages>
			<li>
				<statFactors>
					<MeleeArmorPenetration>1.55</MeleeArmorPenetration>
					<MeleeCooldownFactor>0.6</MeleeCooldownFactor>
					<MeleeHitChance>1.35</MeleeHitChance>
					<MoveSpeed>1.2</MoveSpeed>
				</statFactors>
			</li>
		</stages>
	</HediffDef>

	<HediffDef>
		<defName>crimsondynasty_predator</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>predator grace</label>
		<description>Predatory reflexes grant fast closes, clean strikes, and precise body control.</description>
		<defaultLabelColor>(178,34,34)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>Moving</capacity>
						<offset>0.30</offset>
					</li>
					<li>
						<capacity>Manipulation</capacity>
						<offset>0.25</offset>
					</li>
				</capMods>
				<statFactors>
					<MoveSpeed>1.25</MoveSpeed>
					<MeleeCooldownFactor>0.65</MeleeCooldownFactor>
					<MeleeDamageFactor>1.5</MeleeDamageFactor>
					<MeleeHitChance>1.35</MeleeHitChance>
					<MeleeDodgeChance>1.35</MeleeDodgeChance>
				</statFactors>
			</li>
		</stages>
	</HediffDef>

	<HediffDef>
		<defName>crimsondynasty_hemogenic</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>hemogenic vigor</label>
		<description>Blood chemistry turns preternaturally efficient, accelerating recovery and resistance.</description>
		<defaultLabelColor>(178,34,34)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>BloodFiltration</capacity>
						<offset>0.30</offset>
					</li>
					<li>
						<capacity>BloodPumping</capacity>
						<offset>0.25</offset>
					</li>
					<li>
						<capacity>Metabolism</capacity>
						<offset>0.20</offset>
					</li>
				</capMods>
				<regeneration>70</regeneration>
				<statFactors>
					<ImmunityGainSpeed>2.1</ImmunityGainSpeed>
					<InjuryHealingFactor>2.25</InjuryHealingFactor>
					<RestRateMultiplier>1.65</RestRateMultiplier>
				</statFactors>
			</li>
		</stages>
	</HediffDef>

	<HediffDef>
		<defName>crimsondynasty_mesmer</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>mesmeric authority</label>
		<description>A cold aristocratic presence unsettles rivals and compels obedience in conversation.</description>
		<defaultLabelColor>(178,34,34)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<statOffsets>
					<MentalBreakThreshold>-0.20</MentalBreakThreshold>
				</statOffsets>
				<statFactors>
					<SocialImpact>1.8</SocialImpact>
					<NegotiationAbility>1.5</NegotiationAbility>
					<TradePriceImprovement>1.2</TradePriceImprovement>
				</statFactors>
			</li>
		</stages>
	</HediffDef>

	<HediffDef>
		<defName>crimsondynasty_dreadguard</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>dreadguard resilience</label>
		<description>Battle-hardened bloodline resilience dampens pain and keeps the host fighting through mortal wounds, but open flame remains dangerous.</description>
		<defaultLabelColor>(178,34,34)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<painFactor>0.35</painFactor>
				<statOffsets>
					<ArmorRating_Blunt>0.4</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.4</ArmorRating_Sharp>
					<ArmorRating_Heat>0.25</ArmorRating_Heat>
				</statOffsets>
				<statFactors>
					<IncomingDamageFactor>0.62</IncomingDamageFactor>
					<Flammability>1.3</Flammability>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>crimson_bloodrush_surge</defName>
		<hediffClass>HediffWithComps</hediffClass>
		<label>bloodrush surge</label>
		<description>The lineage is forcibly overdriven into a frenzy state. Lethality and speed explode, while restraint vanishes.</description>
		<defaultLabelColor>(178,34,34)</defaultLabelColor>
		<isBad>false</isBad>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>2400</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
			</li>
		</comps>
		<stages>
			<li>
				<statFactors>
					<MeleeDamageFactor>1.7</MeleeDamageFactor>
					<MeleeCooldownFactor>0.5</MeleeCooldownFactor>
					<MeleeHitChance>1.4</MeleeHitChance>
					<MoveSpeed>1.4</MoveSpeed>
					<IncomingDamageFactor>1.28</IncomingDamageFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>crimson_sovereign_gaze_marked</defName>
		<hediffClass>HediffWithComps</hediffClass>
		<label>sovereign gaze marked</label>
		<description>The target's will falters under predatory authority, reducing coordination and resistance.</description>
		<defaultLabelColor>(178,34,34)</defaultLabelColor>
		<isBad>true</isBad>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>2400</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
			</li>
		</comps>
		<stages>
			<li>
				<statFactors>
					<MoveSpeed>0.72</MoveSpeed>
					<MeleeDodgeChance>0.6</MeleeDodgeChance>
					<IncomingDamageFactor>1.32</IncomingDamageFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
</Defs>
